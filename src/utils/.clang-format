BasedOnStyle: Google
ColumnLimit: 160
IndentWidth: 4
IndentPPDirectives: AfterHash
SortIncludes: true

# 1. Stop clang-format from treating "ixbutil.h" as the "main" header
IncludeIsMainRegex: '_never_match_' 

# 2. Define custom sorting priorities (lower Priority number goes first)
IncludeCategories:
  - Regex:    '^<Xm/'   # Motif headers at the absolute top
    Priority: 1
  - Regex:    '^<X11/'  # X11 headers right after Motif
    Priority: 2
  - Regex:    '^<.*>'   # Standard system headers (e.g., <stdio.h>)
    Priority: 3
  - Regex:    '^".*"'   # Local project headers (e.g., "ixbutil.h")
    Priority: 4
